# Frontend-only mode (no backend required)
# Платежи симулируются на фронтенде, реального списания не происходит
VITE_DEMO_MODE=true

# FreedomPay Configuration
# Получите MERCHANT_ID в личном кабинете FreedomPay
# Документация: https://docs.freedompay.kz/
VITE_FREEDOMPAY_MERCHANT_ID=your_merchant_id
VITE_FREEDOMPAY_TEST_MODE=true
