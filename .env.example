# API Backend URL
VITE_API_BASE_URL=http://localhost:8000

# Demo Mode (without backend) - set to 'true' for testing
# В демо-режиме оплата работает без реального бэкенда
VITE_DEMO_MODE=true

# Robokassa Test Credentials
# Получите тестовые креденшиалы в личном кабинете Robokassa (https://auth.robokassa.kz)
# В разделе "Технические настройки" -> "Тестовый режим"
VITE_ROBOKASSA_LOGIN=your_test_login
VITE_ROBOKASSA_PASSWORD1=your_test_password_1
VITE_ROBOKASSA_PASSWORD2=your_test_password_2
